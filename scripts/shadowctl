#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import pathlib
import re
import shlex
import socket
import subprocess
import sys
from typing import Any


def repo_root() -> pathlib.Path:
    return pathlib.Path(__file__).resolve().parent.parent


def state_dir() -> pathlib.Path:
    return repo_root() / ".shadow-vm"


def socket_path() -> pathlib.Path:
    return state_dir() / "shadow-ui-vm.sock"


def ssh_port() -> str:
    return os.environ.get("SHADOW_UI_VM_SSH_PORT", "2222")


def ssh_base() -> list[str]:
    return [
        "ssh",
        "-p",
        ssh_port(),
        "-o",
        "LogLevel=ERROR",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        "UserKnownHostsFile=/dev/null",
        "shadow@127.0.0.1",
    ]


def run_local(command: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, text=True, capture_output=True, check=check)


def run_remote(
    script: str,
    *,
    capture_output: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    command = ssh_base() + [shlex.join(["bash", "-lc", script])]
    return subprocess.run(command, text=True, capture_output=capture_output, check=check)


def vm_processes() -> list[str]:
    result = run_local(["pgrep", "-f", "microvm@shadow-ui-vm"], check=False)
    if result.returncode != 0:
        return []
    pids = [pid for pid in result.stdout.split() if pid.strip()]
    if not pids:
        return []
    process_list = run_local(["ps", "-p", ",".join(pids), "-o", "pid=,command="], check=False)
    if process_list.returncode != 0:
        return pids
    return [line for line in process_list.stdout.splitlines() if line.strip()]


def vm_repo_source(process_lines: list[str]) -> str | None:
    pattern = re.compile(r"-fsdev local,id=fs1,path=([^,]+),security_model=none,readonly=false")
    for line in process_lines:
        match = pattern.search(line)
        if match:
            return match.group(1)
    return None


def running_apps(process_lines: list[str]) -> list[str]:
    apps: list[str] = []
    names = ("shadow-counter",)
    for line in process_lines:
        for name in names:
            if f" {name}" in f" {line}" or name in line:
                apps.append(name)
    return sorted(set(apps))


def qmp_request(command: str, arguments: dict[str, Any] | None = None) -> dict[str, Any]:
    qmp_socket = socket_path()
    if not qmp_socket.exists():
        raise FileNotFoundError(f"shadowctl: missing QMP socket {qmp_socket}")

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.connect(str(qmp_socket))
        greeting = _qmp_read_message(client)
        if "QMP" not in greeting:
            raise RuntimeError(f"shadowctl: unexpected QMP greeting: {greeting!r}")

        _qmp_send_message(client, {"execute": "qmp_capabilities"})
        capabilities = _qmp_read_message(client)
        if "return" not in capabilities:
            raise RuntimeError(f"shadowctl: failed to negotiate QMP capabilities: {capabilities!r}")

        payload: dict[str, Any] = {"execute": command}
        if arguments:
            payload["arguments"] = arguments
        _qmp_send_message(client, payload)
        response = _qmp_read_message(client)
        if "error" in response:
            raise RuntimeError(f"shadowctl: QMP {command} failed: {response['error']}")
        return response


def _qmp_send_message(client: socket.socket, payload: dict[str, Any]) -> None:
    client.sendall(json.dumps(payload).encode("utf-8") + b"\n")


def _qmp_read_message(client: socket.socket) -> dict[str, Any]:
    data = bytearray()
    while True:
        chunk = client.recv(4096)
        if not chunk:
            raise RuntimeError("shadowctl: unexpected EOF from QMP socket")
        data.extend(chunk)
        while b"\n" in data:
            raw_line, _, remainder = data.partition(b"\n")
            data[:] = remainder
            line = raw_line.strip()
            if not line:
                continue
            message = json.loads(line.decode("utf-8"))
            if "event" in message:
                continue
            return message


def vm_status_payload() -> dict[str, Any]:
    local_processes = vm_processes()
    payload: dict[str, Any] = {
        "local": {
            "state_dir": str(state_dir()),
            "socket_path": str(socket_path()),
            "socket_exists": socket_path().exists(),
            "vm_processes": local_processes,
            "repo_source": vm_repo_source(local_processes),
        }
    }

    remote_script = r"""
set -euo pipefail
uid="$(id -u shadow 2>/dev/null || id -u)"
runtime_dir="/run/user/${uid}"
session_log="/var/lib/shadow-ui/log/shadow-ui-session.log"
control_socket="${runtime_dir}/shadow-control.sock"
python3 - <<'PY'
import json
import pathlib
import subprocess

runtime_dir = pathlib.Path("/run/user/1000")
session_log = pathlib.Path("/var/lib/shadow-ui/log/shadow-ui-session.log")
control_socket = runtime_dir / "shadow-control.sock"

def cmd(*argv):
    result = subprocess.run(argv, text=True, capture_output=True, check=False)
    return result.returncode, result.stdout, result.stderr

service_props = {}
for line in cmd("systemctl", "show", "shadow-ui-smoke.service", "-p", "ActiveState", "-p", "SubState", "-p", "Result")[1].splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        service_props[key] = value

process_lines = []
for line in cmd("ps", "-eo", "pid=,comm=,args=")[1].splitlines():
    if any(name in line for name in ("shadow-compositor", "shadow-ui-desktop", "shadow-counter", "cargo run")):
        if "python3 - <<'PY'" in line:
            continue
        process_lines.append(line.strip())

log_tail = []
if session_log.exists():
    log_tail = session_log.read_text().splitlines()[-40:]

payload = {
    "service": service_props,
    "runtime_dir": str(runtime_dir),
    "wayland_sockets": sorted(path.name for path in runtime_dir.glob("wayland-*") if path.is_socket()),
    "control_socket_exists": control_socket.exists(),
    "processes": process_lines,
    "session_log_tail": log_tail,
}
print(json.dumps(payload))
PY
"""

    remote = run_remote(remote_script, check=False)
    payload["remote"] = {
        "reachable": remote.returncode == 0,
        "returncode": remote.returncode,
        "stderr": remote.stderr.strip(),
    }
    if remote.returncode == 0 and remote.stdout.strip():
        payload["remote"].update(json.loads(remote.stdout))
        remote_processes = payload["remote"].get("processes", [])
        compiling = any(
            marker in line
            for line in remote_processes
            for marker in ("cargo", "rustc")
        )
        payload["remote"]["running_apps"] = running_apps(remote_processes)
        payload["remote"]["ui_ready"] = bool(
            payload["remote"].get("control_socket_exists")
            and "shadow-composit" in "\n".join(remote_processes)
            and "shadow-ui-deskt" in "\n".join(remote_processes)
        )
        payload["remote"]["compile_in_progress"] = compiling
    return payload


def print_status(payload: dict[str, Any]) -> None:
    local = payload["local"]
    remote = payload["remote"]
    print(f"socket: {'yes' if local['socket_exists'] else 'no'} ({local['socket_path']})")
    if local["vm_processes"]:
        print("vm process:")
        for line in local["vm_processes"]:
            print(f"  {line}")
    else:
        print("vm process: not running")
    if local.get("repo_source"):
        print(f"vm repo source: {local['repo_source']}")

    print(f"remote reachable: {'yes' if remote.get('reachable') else 'no'}")
    if not remote.get("reachable"):
        if remote.get("stderr"):
            print(remote["stderr"])
        return

    service = remote.get("service", {})
    print(
        "shadow-ui-smoke:",
        f"{service.get('ActiveState', 'unknown')}/{service.get('SubState', 'unknown')}",
        f"result={service.get('Result', 'unknown')}",
    )
    print("wayland sockets:", ", ".join(remote.get("wayland_sockets", [])) or "none")
    print("control socket:", "yes" if remote.get("control_socket_exists") else "no")
    if remote.get("running_apps"):
        print("running apps:", ", ".join(remote["running_apps"]))
    print("ui ready:", "yes" if remote.get("ui_ready") else "no")
    if remote.get("compile_in_progress"):
        print("compile:", "in progress")
    print("processes:")
    for line in remote.get("processes", []):
        print(f"  {line}")


def diagnose(payload: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    remote = payload["remote"]
    if not remote.get("reachable"):
        issues.append("VM guest is not reachable over SSH.")
        return issues

    if payload["local"].get("repo_source") not in (None, str(repo_root())):
        issues.append(
            f"VM is mounted from {payload['local']['repo_source']}, not {repo_root()}."
        )

    processes = "\n".join(remote.get("processes", []))
    log_tail = remote.get("session_log_tail", [])

    if "shadow-compositor" in processes and "shadow-ui-desktop" not in processes:
        issues.append("Compositor is running but shadow-ui-desktop is not.")
    if any("shadow-ui-desktop exited" in line for line in log_tail):
        issues.append("Session log shows shadow-ui-desktop exited immediately.")
    if not remote.get("control_socket_exists"):
        issues.append("Compositor control socket is missing.")
    if not remote.get("wayland_sockets"):
        issues.append("No Wayland sockets are present in the guest runtime dir.")
    if remote.get("compile_in_progress") and not remote.get("ui_ready"):
        issues.append("Guest UI build is still in progress; blank compositor background is expected.")
    return issues


def control_request(command: str) -> subprocess.CompletedProcess[str]:
    script = f"""
set -euo pipefail
export XDG_RUNTIME_DIR="${{XDG_RUNTIME_DIR:-/run/user/$(id -u)}}"
control_socket="$XDG_RUNTIME_DIR/shadow-control.sock"
if [[ ! -S "$control_socket" ]]; then
  echo "shadowctl: missing compositor control socket $control_socket" >&2
  exit 1
fi
export SHADOWCTL_CONTROL_SOCKET="$control_socket"
python3 - <<'PY'
import os
import socket
import sys
path = os.environ["SHADOWCTL_CONTROL_SOCKET"]
payload = {command!r}.encode("utf-8") + b"\\n"
with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
    client.connect(path)
    client.sendall(payload)
    client.shutdown(socket.SHUT_WR)
    chunks = []
    while True:
        chunk = client.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
sys.stdout.write(b"".join(chunks).decode("utf-8"))
PY
"""
    return run_remote(script, capture_output=True, check=False)


def parse_control_state(response: str) -> dict[str, Any]:
    state: dict[str, Any] = {}
    for line in response.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        state[key] = value

    return {
        "focused": state.get("focused") or None,
        "mapped": [item for item in state.get("mapped", "").split(",") if item],
        "launched": [item for item in state.get("launched", "").split(",") if item],
        "windows": int(state.get("windows", "0")),
        "socket": state.get("socket") or None,
    }


def cmd_vm_status(args: argparse.Namespace) -> int:
    payload = vm_status_payload()
    if args.json:
      print(json.dumps(payload, indent=2, sort_keys=True))
    else:
      print_status(payload)
    return 0


def cmd_vm_logs(args: argparse.Namespace) -> int:
    script = f"tail -n {args.lines} /var/lib/shadow-ui/log/shadow-ui-session.log"
    result = run_remote(script, capture_output=False, check=False)
    return result.returncode


def cmd_vm_journal(args: argparse.Namespace) -> int:
    script = f"journalctl -b -u greetd.service -u shadow-ui-smoke.service --no-pager -n {args.lines}"
    result = run_remote(script, capture_output=False, check=False)
    return result.returncode


def cmd_vm_doctor(args: argparse.Namespace) -> int:
    payload = vm_status_payload()
    issues = diagnose(payload)
    if args.json:
        print(json.dumps({"status": payload, "issues": issues}, indent=2, sort_keys=True))
    else:
        print_status(payload)
        print()
        if issues:
            print("diagnosis:")
            for issue in issues:
                print(f"  - {issue}")
        else:
            print("diagnosis: no obvious issues detected")
    return 0


def cmd_vm_screenshot(args: argparse.Namespace) -> int:
    output = pathlib.Path(args.output).expanduser()
    if not output.is_absolute():
        output = repo_root() / output
    output.parent.mkdir(parents=True, exist_ok=True)
    qmp_request("screendump", {"filename": str(output)})
    print(output)
    return 0


def cmd_vm_state(args: argparse.Namespace) -> int:
    payload = vm_status_payload()
    if payload["remote"].get("control_socket_exists"):
        result = control_request("state")
        if result.returncode != 0:
            if result.stderr:
                print(result.stderr, end="", file=sys.stderr)
            return result.returncode
        state = parse_control_state(result.stdout)
    else:
        state = {
            "focused": None,
            "mapped": payload["remote"].get("running_apps", []),
            "launched": payload["remote"].get("running_apps", []),
            "windows": 0,
            "socket": None,
            "compile_in_progress": payload["remote"].get("compile_in_progress"),
            "ui_ready": payload["remote"].get("ui_ready"),
            "remote_reachable": payload["remote"].get("reachable"),
        }
    if args.json:
        print(json.dumps(state, indent=2, sort_keys=True))
    else:
        print(f"focused={state['focused'] or ''}")
        print(f"mapped={','.join(state['mapped'])}")
        print(f"launched={','.join(state['launched'])}")
        print(f"windows={state['windows']}")
        print(f"socket={state['socket'] or ''}")
    return 0


def cmd_vm_open(args: argparse.Namespace) -> int:
    result = control_request(f"launch {args.app_id}")
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def cmd_vm_home(_args: argparse.Namespace) -> int:
    result = control_request("home")
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def cmd_vm_switcher(_args: argparse.Namespace) -> int:
    result = control_request("switcher")
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def cmd_vm_wait_ready(args: argparse.Namespace) -> int:
    import time

    deadline = time.time() + args.timeout
    while time.time() < deadline:
        payload = vm_status_payload()
        if payload["remote"].get("ui_ready"):
            if args.json:
                print(json.dumps(payload, indent=2, sort_keys=True))
            else:
                print("ui ready")
            return 0
        time.sleep(args.interval)
    print("shadowctl: timed out waiting for UI readiness", file=sys.stderr)
    return 1


def cmd_vm_run(args: argparse.Namespace) -> int:
    package = args.package
    log_file = f"/var/lib/shadow-ui/log/{package}.log"
    session_env_file = "/var/lib/shadow-ui/shadow-ui-session-env.sh"
    mode = "background" if args.background else "foreground"
    env_assignments = []
    for item in args.env:
        if "=" not in item:
            raise SystemExit(f"shadowctl: expected KEY=VALUE for --env, got {item!r}")
        key, value = item.split("=", 1)
        if not key:
            raise SystemExit(f"shadowctl: invalid empty env key in {item!r}")
        env_assignments.append(f"{key}={shlex.quote(value)}")
    env_prefix = " ".join(env_assignments)
    env_prefix = f"{env_prefix} " if env_prefix else ""

    remote_script = f"""
set -euo pipefail
export XDG_RUNTIME_DIR="${{XDG_RUNTIME_DIR:-/run/user/$(id -u)}}"
session_env_file={shlex.quote(session_env_file)}
package={shlex.quote(package)}
log_file={shlex.quote(log_file)}

load_session_env_from_process() {{
  local session_pid
  session_pid="$(pgrep -o -f 'shadow-compositor' || true)"
  if [[ -z "$session_pid" ]]; then
    echo "shadowctl: could not find a running shadow-compositor" >&2
    exit 1
  fi

  while IFS= read -r -d '' entry; do
    case "$entry" in
      HOME=*|XDG_CACHE_HOME=*|CARGO_TARGET_DIR=*|PKG_CONFIG_PATH=*|LD_LIBRARY_PATH=*|LIBRARY_PATH=*|NIX_LDFLAGS=*|LIBGL_DRIVERS_PATH=*|RUST_BACKTRACE=*|XDG_RUNTIME_DIR=*)
        export "$entry"
        ;;
    esac
  done <"/proc/$session_pid/environ"
}}

if [[ -f "$session_env_file" ]]; then
  source "$session_env_file"
else
  load_session_env_from_process
fi

wayland_socket="$(find "$XDG_RUNTIME_DIR" -maxdepth 1 -type s -name 'wayland-*' -printf '%f\\n' | sort -V | tail -n 1)"
control_socket="$XDG_RUNTIME_DIR/shadow-control.sock"

if [[ -z "$wayland_socket" ]]; then
  echo "shadowctl: no wayland socket found in $XDG_RUNTIME_DIR" >&2
  exit 1
fi

if [[ ! -S "$control_socket" ]]; then
  echo "shadowctl: missing compositor control socket $control_socket" >&2
  exit 1
fi

cd /work/shadow
cmd=(env WAYLAND_DISPLAY="$wayland_socket" SHADOW_COMPOSITOR_CONTROL="$control_socket" {env_prefix}cargo run --locked --manifest-path ui/Cargo.toml -p "$package")

echo "mode={mode}"
echo "wayland=$wayland_socket"
echo "control=$control_socket"
if [[ {shlex.quote("1" if args.background else "0")} == "1" ]]; then
  nohup "${{cmd[@]}}" >"$log_file" 2>&1 </dev/null &
  sleep 1
  echo "log=$log_file"
else
  exec "${{cmd[@]}}"
fi
"""

    result = run_remote(remote_script, capture_output=not args.background, check=False)
    if args.background:
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        return result.returncode
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="shadowctl")
    subparsers = parser.add_subparsers(dest="command", required=True)

    vm = subparsers.add_parser("vm")
    vm_sub = vm.add_subparsers(dest="vm_command", required=True)

    status = vm_sub.add_parser("status")
    status.add_argument("--json", action="store_true")
    status.set_defaults(func=cmd_vm_status)

    logs = vm_sub.add_parser("logs")
    logs.add_argument("--lines", type=int, default=200)
    logs.set_defaults(func=cmd_vm_logs)

    journal = vm_sub.add_parser("journal")
    journal.add_argument("--lines", type=int, default=200)
    journal.set_defaults(func=cmd_vm_journal)

    doctor = vm_sub.add_parser("doctor")
    doctor.add_argument("--json", action="store_true")
    doctor.set_defaults(func=cmd_vm_doctor)

    state = vm_sub.add_parser("state")
    state.add_argument("--json", action="store_true")
    state.set_defaults(func=cmd_vm_state)

    screenshot = vm_sub.add_parser("screenshot")
    screenshot.add_argument("output", nargs="?", default="build/ui-vm/shadow-ui-vm.ppm")
    screenshot.set_defaults(func=cmd_vm_screenshot)

    open_cmd = vm_sub.add_parser("open")
    open_cmd.add_argument("app_id")
    open_cmd.set_defaults(func=cmd_vm_open)

    home = vm_sub.add_parser("home")
    home.set_defaults(func=cmd_vm_home)

    switcher = vm_sub.add_parser("switcher")
    switcher.set_defaults(func=cmd_vm_switcher)

    wait_ready = vm_sub.add_parser("wait-ready")
    wait_ready.add_argument("--timeout", type=int, default=300)
    wait_ready.add_argument("--interval", type=float, default=1.0)
    wait_ready.add_argument("--json", action="store_true")
    wait_ready.set_defaults(func=cmd_vm_wait_ready)

    run = vm_sub.add_parser("run")
    run.add_argument("package")
    run.add_argument("--env", action="append", default=[])
    run.add_argument("--background", action="store_true")
    run.set_defaults(func=cmd_vm_run)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
