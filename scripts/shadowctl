#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import pathlib
import re
import shlex
import socket
import subprocess
import sys
from typing import Any


def repo_root() -> pathlib.Path:
    return pathlib.Path(__file__).resolve().parent.parent


def state_dir() -> pathlib.Path:
    return repo_root() / ".shadow-vm"


def socket_path() -> pathlib.Path:
    return state_dir() / "shadow-ui-vm.sock"


def ssh_port() -> str:
    return os.environ.get("SHADOW_UI_VM_SSH_PORT", "2222")


def ssh_base() -> list[str]:
    return [
        "ssh",
        "-p",
        ssh_port(),
        "-o",
        "LogLevel=ERROR",
        "-o",
        "StrictHostKeyChecking=no",
        "-o",
        "UserKnownHostsFile=/dev/null",
        "shadow@127.0.0.1",
    ]


def run_local(command: list[str], *, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, text=True, capture_output=True, check=check)


def run_remote(
    script: str,
    *,
    capture_output: bool = True,
    check: bool = True,
) -> subprocess.CompletedProcess[str]:
    command = ssh_base() + [shlex.join(["bash", "-lc", script])]
    return subprocess.run(command, text=True, capture_output=capture_output, check=check)


def vm_processes() -> list[str]:
    result = run_local(["pgrep", "-f", "microvm@shadow-ui-vm"], check=False)
    if result.returncode != 0:
        return []
    pids = [pid for pid in result.stdout.split() if pid.strip()]
    if not pids:
        return []
    process_list = run_local(["ps", "-p", ",".join(pids), "-o", "pid=,command="], check=False)
    if process_list.returncode != 0:
        return pids
    return [line for line in process_list.stdout.splitlines() if line.strip()]


def vm_repo_source(process_lines: list[str]) -> str | None:
    pattern = re.compile(r"-fsdev local,id=fs1,path=([^,]+),security_model=none,readonly=false")
    for line in process_lines:
        match = pattern.search(line)
        if match:
            return match.group(1)
    return None


def qmp_request(command: str, arguments: dict[str, Any] | None = None) -> dict[str, Any]:
    qmp_socket = socket_path()
    if not qmp_socket.exists():
        raise FileNotFoundError(f"shadowctl: missing QMP socket {qmp_socket}")

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.connect(str(qmp_socket))
        greeting = _qmp_read_message(client)
        if "QMP" not in greeting:
            raise RuntimeError(f"shadowctl: unexpected QMP greeting: {greeting!r}")

        _qmp_send_message(client, {"execute": "qmp_capabilities"})
        capabilities = _qmp_read_message(client)
        if "return" not in capabilities:
            raise RuntimeError(f"shadowctl: failed to negotiate QMP capabilities: {capabilities!r}")

        payload: dict[str, Any] = {"execute": command}
        if arguments:
            payload["arguments"] = arguments
        _qmp_send_message(client, payload)
        response = _qmp_read_message(client)
        if "error" in response:
            raise RuntimeError(f"shadowctl: QMP {command} failed: {response['error']}")
        return response


def _qmp_send_message(client: socket.socket, payload: dict[str, Any]) -> None:
    client.sendall(json.dumps(payload).encode("utf-8") + b"\n")


def _qmp_read_message(client: socket.socket) -> dict[str, Any]:
    data = bytearray()
    while True:
        chunk = client.recv(4096)
        if not chunk:
            raise RuntimeError("shadowctl: unexpected EOF from QMP socket")
        data.extend(chunk)
        while b"\n" in data:
            raw_line, _, remainder = data.partition(b"\n")
            data[:] = remainder
            line = raw_line.strip()
            if not line:
                continue
            message = json.loads(line.decode("utf-8"))
            if "event" in message:
                continue
            return message


def run_remote_json(script: str) -> dict[str, Any]:
    remote = run_remote(script, check=False)
    payload: dict[str, Any] = {
        "reachable": remote.returncode == 0,
        "returncode": remote.returncode,
        "stderr": remote.stderr.strip(),
    }
    if remote.returncode == 0 and remote.stdout.strip():
        payload.update(json.loads(remote.stdout))
    return payload


def vm_status_payload() -> dict[str, Any]:
    local_processes = vm_processes()
    payload: dict[str, Any] = {
        "local": {
            "state_dir": str(state_dir()),
            "socket_path": str(socket_path()),
            "socket_exists": socket_path().exists(),
            "vm_processes": local_processes,
            "repo_source": vm_repo_source(local_processes),
        }
    }
    payload["remote"] = run_remote_json(
        r"""
set -euo pipefail
python3 - <<'PY'
import json
import pathlib
import subprocess

runtime_dir = pathlib.Path("/run/user/1000")
state_dir = pathlib.Path("/var/lib/shadow-ui")
session_log = state_dir / "log" / "shadow-ui-session.log"
weston_log = state_dir / "log" / "weston.log"
control_socket = runtime_dir / "shadow-control.sock"
session_env = state_dir / "shadow-ui-session-env.sh"
nested_env = state_dir / "shadow-compositor-session-env.sh"

def cmd(*argv):
    result = subprocess.run(argv, text=True, capture_output=True, check=False)
    return result.returncode, result.stdout, result.stderr

service_props = {}
for line in cmd("systemctl", "show", "shadow-ui-smoke.service", "-p", "ActiveState", "-p", "SubState", "-p", "Result")[1].splitlines():
    if "=" in line:
        key, value = line.split("=", 1)
        service_props[key] = value

process_lines = []
needles = (
    "weston",
    "shadow-ui-desktop",
    "shadow-compositor",
    "shadow-counter",
    "shadow-status",
    "shadow-cog-demo",
    "shadow-blitz-demo",
    "epiphany",
    "deno run",
    "cargo run --locked --manifest-path ui/Cargo.toml",
)
for line in cmd("ps", "-eo", "pid=,comm=,args=")[1].splitlines():
    if any(name in line for name in needles):
        if "python3 - <<'PY'" in line:
            continue
        process_lines.append(line.strip())

def tail(path):
    if not path.exists():
        return []
    return path.read_text().splitlines()[-40:]

payload = {
    "service": service_props,
    "runtime_dir": str(runtime_dir),
    "wayland_sockets": sorted(path.name for path in runtime_dir.glob("wayland-*") if path.is_socket()),
    "outer_control_socket_exists": control_socket.exists(),
    "outer_session_env_exists": session_env.exists(),
    "nested_session_env_exists": nested_env.exists(),
    "processes": process_lines,
    "session_log_tail": tail(session_log),
    "weston_log_tail": tail(weston_log),
}
print(json.dumps(payload))
PY
"""
    )
    return payload


def shadow_status_payload() -> dict[str, Any]:
    payload: dict[str, Any] = {"local": {"state_dir": str(state_dir())}}
    payload["remote"] = run_remote_json(
        r"""
set -euo pipefail
python3 - <<'PY'
import json
import pathlib
import subprocess

runtime_dir = pathlib.Path("/run/user/1000")
state_dir = pathlib.Path("/var/lib/shadow-ui")
env_file = state_dir / "shadow-compositor-session-env.sh"
log_file = state_dir / "log" / "shadow-compositor.log"

env_map = {}
if env_file.exists():
    for line in env_file.read_text().splitlines():
        line = line.strip()
        if not line.startswith("export ") or "=" not in line:
            continue
        key, value = line[len("export "):].split("=", 1)
        env_map[key] = value.strip().strip('"')

wayland_display = env_map.get("WAYLAND_DISPLAY")
control_socket = env_map.get("SHADOW_COMPOSITOR_CONTROL")

def cmd(*argv):
    result = subprocess.run(argv, text=True, capture_output=True, check=False)
    return result.returncode, result.stdout, result.stderr

process_lines = []
needles = (
    "shadow-compositor",
    "shadow-counter",
    "shadow-status",
    "shadow-cog-demo",
    "shadow-blitz-demo",
    "epiphany",
    "deno run",
    "cargo run --locked --manifest-path ui/Cargo.toml",
)
for line in cmd("ps", "-eo", "pid=,comm=,args=")[1].splitlines():
    if any(name in line for name in needles):
        if "python3 - <<'PY'" in line:
            continue
        process_lines.append(line.strip())

log_tail = []
if log_file.exists():
    log_tail = log_file.read_text().splitlines()[-60:]

payload = {
    "env_file_exists": env_file.exists(),
    "wayland_display": wayland_display,
    "wayland_socket_exists": bool(wayland_display) and (runtime_dir / wayland_display).is_socket(),
    "control_socket": control_socket,
    "control_socket_exists": bool(control_socket) and pathlib.Path(control_socket).is_socket(),
    "processes": process_lines,
    "log_tail": log_tail,
}
print(json.dumps(payload))
PY
"""
    )
    return payload


def print_vm_status(payload: dict[str, Any]) -> None:
    local = payload["local"]
    remote = payload["remote"]
    print(f"socket: {'yes' if local['socket_exists'] else 'no'} ({local['socket_path']})")
    if local["vm_processes"]:
        print("vm process:")
        for line in local["vm_processes"]:
            print(f"  {line}")
    else:
        print("vm process: not running")
    if local.get("repo_source"):
        print(f"vm repo source: {local['repo_source']}")

    print(f"remote reachable: {'yes' if remote.get('reachable') else 'no'}")
    if not remote.get("reachable"):
        if remote.get("stderr"):
            print(remote["stderr"])
        return

    service = remote.get("service", {})
    print(
        "shadow-ui-smoke:",
        f"{service.get('ActiveState', 'unknown')}/{service.get('SubState', 'unknown')}",
        f"result={service.get('Result', 'unknown')}",
    )
    print("wayland sockets:", ", ".join(remote.get("wayland_sockets", [])) or "none")
    print("outer control socket:", "yes" if remote.get("outer_control_socket_exists") else "no")
    print("outer session env:", "yes" if remote.get("outer_session_env_exists") else "no")
    print("nested session env:", "yes" if remote.get("nested_session_env_exists") else "no")
    print("processes:")
    for line in remote.get("processes", []):
        print(f"  {line}")


def print_shadow_status(payload: dict[str, Any]) -> None:
    remote = payload["remote"]
    print(f"remote reachable: {'yes' if remote.get('reachable') else 'no'}")
    if not remote.get("reachable"):
        if remote.get("stderr"):
            print(remote["stderr"])
        return

    print("nested env:", "yes" if remote.get("env_file_exists") else "no")
    print("nested wayland:", remote.get("wayland_display") or "missing")
    print("nested wayland socket:", "yes" if remote.get("wayland_socket_exists") else "no")
    control = remote.get("control_socket") or "missing"
    print(f"nested control socket: {control}")
    print("control socket exists:", "yes" if remote.get("control_socket_exists") else "no")
    print("processes:")
    for line in remote.get("processes", []):
        print(f"  {line}")


def diagnose_vm(payload: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    remote = payload["remote"]
    if not remote.get("reachable"):
        issues.append("VM guest is not reachable over SSH.")
        return issues

    if payload["local"].get("repo_source") not in (None, str(repo_root())):
        issues.append(f"VM is mounted from {payload['local']['repo_source']}, not {repo_root()}.")

    processes = "\n".join(remote.get("processes", []))
    session_log_tail = remote.get("session_log_tail", [])

    if "weston" not in processes:
        issues.append("Weston is not running in the guest session.")
    if "shadow-ui-desktop" not in processes:
        issues.append("shadow-ui-desktop is not running.")
    if any("shadow-ui-desktop exited" in line for line in session_log_tail):
        issues.append("Session log shows shadow-ui-desktop exited immediately.")
    if not remote.get("wayland_sockets"):
        issues.append("No Wayland sockets are present in the guest runtime dir.")
    if not remote.get("outer_session_env_exists"):
        issues.append("Outer session env file is missing.")
    return issues


def diagnose_shadow(payload: dict[str, Any]) -> list[str]:
    issues: list[str] = []
    remote = payload["remote"]
    if not remote.get("reachable"):
        issues.append("VM guest is not reachable over SSH.")
        return issues

    processes = "\n".join(remote.get("processes", []))

    if not remote.get("env_file_exists"):
        issues.append("Nested compositor env file is missing.")
    if "shadow-compositor" not in processes:
        issues.append("Nested shadow-compositor is not running.")
    if not remote.get("wayland_socket_exists"):
        issues.append("Nested Wayland socket is missing.")
    if not remote.get("control_socket_exists"):
        issues.append("Nested compositor control socket is missing.")
    if not remote.get("log_tail"):
        issues.append("Nested compositor log is empty or missing.")
    return issues


def print_doctor(label: str, issues: list[str]) -> None:
    print()
    if issues:
        print(f"{label} diagnosis:")
        for issue in issues:
            print(f"  - {issue}")
    else:
        print(f"{label} diagnosis: no obvious issues detected")


def run_package(
    *,
    package: str,
    env_file: str,
    log_file: str,
    background: bool,
    extra_env: list[str],
) -> int:
    mode = "background" if background else "foreground"
    env_assignments = []
    for item in extra_env:
        if "=" not in item:
            raise SystemExit(f"shadowctl: expected KEY=VALUE for --env, got {item!r}")
        key, value = item.split("=", 1)
        if not key:
            raise SystemExit(f"shadowctl: invalid empty env key in {item!r}")
        env_assignments.append(f"{key}={shlex.quote(value)}")
    env_prefix = " ".join(env_assignments)
    env_prefix = f"{env_prefix} " if env_prefix else ""

    remote_script = f"""
set -euo pipefail
export XDG_RUNTIME_DIR="${{XDG_RUNTIME_DIR:-/run/user/$(id -u)}}"
session_env_file={shlex.quote(env_file)}
package={shlex.quote(package)}
log_file={shlex.quote(log_file)}

load_session_env_from_process() {{
  local session_pid
  session_pid="$(pgrep -o -f 'shadow-compositor|shadow-ui-desktop' || true)"
  if [[ -z "$session_pid" ]]; then
    echo "shadowctl: could not find a running session process" >&2
    exit 1
  fi

  while IFS= read -r -d '' entry; do
    case "$entry" in
      HOME=*|XDG_CACHE_HOME=*|CARGO_TARGET_DIR=*|PKG_CONFIG_PATH=*|LD_LIBRARY_PATH=*|LIBRARY_PATH=*|NIX_LDFLAGS=*|LIBGL_DRIVERS_PATH=*|RUST_BACKTRACE=*|XDG_RUNTIME_DIR=*|DBUS_SESSION_BUS_ADDRESS=*|GDK_BACKEND=*)
        export "$entry"
        ;;
    esac
  done <"/proc/$session_pid/environ"
}}

if [[ -f "$session_env_file" ]]; then
  source "$session_env_file"
else
  load_session_env_from_process
fi

if [[ -z "${{WAYLAND_DISPLAY:-}}" ]]; then
  echo "shadowctl: missing WAYLAND_DISPLAY after loading session env" >&2
  exit 1
fi

cd /work/shadow
cmd=(env WAYLAND_DISPLAY="$WAYLAND_DISPLAY")
if [[ -n "${{SHADOW_COMPOSITOR_CONTROL:-}}" ]]; then
  cmd+=(SHADOW_COMPOSITOR_CONTROL="$SHADOW_COMPOSITOR_CONTROL")
fi
if [[ -n "${{DBUS_SESSION_BUS_ADDRESS:-}}" ]]; then
  cmd+=(DBUS_SESSION_BUS_ADDRESS="$DBUS_SESSION_BUS_ADDRESS")
fi
if [[ -n "${{GDK_BACKEND:-}}" ]]; then
  cmd+=(GDK_BACKEND="$GDK_BACKEND")
fi
cmd+=({env_prefix}cargo run --locked --manifest-path ui/Cargo.toml -p "$package")

echo "mode={mode}"
echo "wayland=$WAYLAND_DISPLAY"
echo "control=${{SHADOW_COMPOSITOR_CONTROL:-}}"
if [[ {shlex.quote("1" if background else "0")} == "1" ]]; then
  nohup "${{cmd[@]}}" >"$log_file" 2>&1 </dev/null &
  sleep 1
  echo "log=$log_file"
else
  exec "${{cmd[@]}}"
fi
"""

    result = run_remote(remote_script, capture_output=not background, check=False)
    if result.stdout:
        print(result.stdout, end="")
    if result.stderr:
        print(result.stderr, end="", file=sys.stderr)
    return result.returncode


def cmd_vm_status(args: argparse.Namespace) -> int:
    payload = vm_status_payload()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_vm_status(payload)
    return 0


def cmd_vm_logs(args: argparse.Namespace) -> int:
    result = run_remote(
        f"bash -lc 'echo ==shadow-ui-session==; tail -n {args.lines} /var/lib/shadow-ui/log/shadow-ui-session.log 2>/dev/null || true; echo; echo ==weston==; tail -n {args.lines} /var/lib/shadow-ui/log/weston.log 2>/dev/null || true'",
        capture_output=False,
        check=False,
    )
    return result.returncode


def cmd_vm_journal(args: argparse.Namespace) -> int:
    script = f"journalctl -b -u greetd.service -u shadow-ui-smoke.service --no-pager -n {args.lines}"
    result = run_remote(script, capture_output=False, check=False)
    return result.returncode


def cmd_vm_doctor(args: argparse.Namespace) -> int:
    payload = vm_status_payload()
    issues = diagnose_vm(payload)
    if args.json:
        print(json.dumps({"status": payload, "issues": issues}, indent=2, sort_keys=True))
    else:
        print_vm_status(payload)
        print_doctor("vm", issues)
    return 0


def cmd_vm_screenshot(args: argparse.Namespace) -> int:
    output = pathlib.Path(args.output).expanduser()
    if not output.is_absolute():
        output = repo_root() / output
    output.parent.mkdir(parents=True, exist_ok=True)
    qmp_request("screendump", {"filename": str(output)})
    print(output)
    return 0


def cmd_vm_run(args: argparse.Namespace) -> int:
    return run_package(
        package=args.package,
        env_file="/var/lib/shadow-ui/shadow-ui-session-env.sh",
        log_file=f"/var/lib/shadow-ui/log/{args.package}.log",
        background=args.background,
        extra_env=args.env,
    )


def cmd_shadow_status(args: argparse.Namespace) -> int:
    payload = shadow_status_payload()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print_shadow_status(payload)
    return 0


def cmd_shadow_logs(args: argparse.Namespace) -> int:
    result = run_remote(
        f"tail -n {args.lines} /var/lib/shadow-ui/log/shadow-compositor.log 2>/dev/null || true",
        capture_output=False,
        check=False,
    )
    return result.returncode


def cmd_shadow_doctor(args: argparse.Namespace) -> int:
    payload = shadow_status_payload()
    issues = diagnose_shadow(payload)
    if args.json:
        print(json.dumps({"status": payload, "issues": issues}, indent=2, sort_keys=True))
    else:
        print_shadow_status(payload)
        print_doctor("shadow", issues)
    return 0


def cmd_shadow_run(args: argparse.Namespace) -> int:
    return run_package(
        package=args.package,
        env_file="/var/lib/shadow-ui/shadow-compositor-session-env.sh",
        log_file=f"/var/lib/shadow-ui/log/{args.package}.shadow.log",
        background=args.background,
        extra_env=args.env,
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="shadowctl")
    subparsers = parser.add_subparsers(dest="command", required=True)

    vm = subparsers.add_parser("vm")
    vm_sub = vm.add_subparsers(dest="vm_command", required=True)

    vm_status = vm_sub.add_parser("status")
    vm_status.add_argument("--json", action="store_true")
    vm_status.set_defaults(func=cmd_vm_status)

    vm_logs = vm_sub.add_parser("logs")
    vm_logs.add_argument("--lines", type=int, default=200)
    vm_logs.set_defaults(func=cmd_vm_logs)

    vm_journal = vm_sub.add_parser("journal")
    vm_journal.add_argument("--lines", type=int, default=200)
    vm_journal.set_defaults(func=cmd_vm_journal)

    vm_doctor = vm_sub.add_parser("doctor")
    vm_doctor.add_argument("--json", action="store_true")
    vm_doctor.set_defaults(func=cmd_vm_doctor)

    vm_screenshot = vm_sub.add_parser("screenshot")
    vm_screenshot.add_argument("output", nargs="?", default="build/ui-vm/shadow-ui-vm.ppm")
    vm_screenshot.set_defaults(func=cmd_vm_screenshot)

    vm_run = vm_sub.add_parser("run")
    vm_run.add_argument("package")
    vm_run.add_argument("--env", action="append", default=[])
    vm_run.add_argument("--background", action="store_true")
    vm_run.set_defaults(func=cmd_vm_run)

    shadow = subparsers.add_parser("shadow")
    shadow_sub = shadow.add_subparsers(dest="shadow_command", required=True)

    shadow_status = shadow_sub.add_parser("status")
    shadow_status.add_argument("--json", action="store_true")
    shadow_status.set_defaults(func=cmd_shadow_status)

    shadow_logs = shadow_sub.add_parser("logs")
    shadow_logs.add_argument("--lines", type=int, default=200)
    shadow_logs.set_defaults(func=cmd_shadow_logs)

    shadow_doctor = shadow_sub.add_parser("doctor")
    shadow_doctor.add_argument("--json", action="store_true")
    shadow_doctor.set_defaults(func=cmd_shadow_doctor)

    shadow_run = shadow_sub.add_parser("run")
    shadow_run.add_argument("package")
    shadow_run.add_argument("--env", action="append", default=[])
    shadow_run.add_argument("--background", action="store_true")
    shadow_run.set_defaults(func=cmd_shadow_run)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
